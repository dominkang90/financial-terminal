# ─────────────────────────────────────────────
# FinTerminal 환경변수 예시
# 이 파일을 .env로 복사하고 값을 채우세요
# ─────────────────────────────────────────────

# 보안 (반드시 변경하세요! 32자 이상 랜덤 문자열)
SECRET_KEY=your-super-secret-key-change-this-now-32chars

# 개발/운영
DEBUG=false

# CORS 허용 도메인 (운영 서버 URL로 변경)
# CORS_ORIGINS=["https://yourdomain.com"]

# ─────────────────────────────────────────────
# 선택적 API 키 (없으면 기본 기능으로 동작)
# ─────────────────────────────────────────────

# Google Gemini API (AI 분석 및 번역)
# 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Finnhub (더 많은 뉴스, 실시간 데이터)
# 발급: https://finnhub.io (무료 60 req/분)
FINNHUB_API_KEY=

# Alpha Vantage (경제 지표, 추가 데이터)
# 발급: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# NewsAPI (뉴스 검색)
# 발급: https://newsapi.org
NEWS_API_KEY=

# ─────────────────────────────────────────────
# 브로커 API (선택, 실거래용)
# ─────────────────────────────────────────────

# Alpaca (Paper Trading 및 미국 주식 실거래)
# 발급: https://alpaca.markets
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Paper trading: https://paper-api.alpaca.markets
# Real trading: https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# 한국투자증권 Open API
# 발급: https://apiportal.koreainvestment.com
KIS_APP_KEY=
KIS_APP_SECRET=

# DART Open API (한국 공시)
# 발급: https://opendart.fss.or.kr
DART_API_KEY=

# ─────────────────────────────────────────────
# 데이터베이스 (기본: SQLite)
# ─────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./financial_terminal.db

# PostgreSQL 사용 시 (Docker Compose 내 postgres 서비스 주석 해제 필요)
# DATABASE_URL=postgresql+asyncpg://finterminal:changeme@postgres/finterminal

# Redis (선택, 캐시 성능 향상)
# REDIS_URL=redis://localhost:6379/0
